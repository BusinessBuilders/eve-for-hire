{
  "name": "eve-for-hire",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "poc:generate": "npx tsx scripts/create-poc-sites.ts",
    "poc:deploy": "npx tsx scripts/swarm-tools/deploy-poc-sites.ts",
    "poc:showcase": "npm run poc:generate && npm run poc:deploy",
    "poc:showcase:dry": "npm run poc:generate && npm run poc:deploy -- --dry-run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.143",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@types/ssh2": "^1.15.5",
    "ai": "^6.0.141",
    "better-sqlite3": "^12.8.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ssh2": "^1.17.0",
    "stripe": "^14.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "prisma": "^6.19.3",
    "typescript": "^5.0.0"
  }
}
