# Anthropic API key — required for /chat (Eve's AI conversation interface)
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Stripe secret key — required for tip jar payments and order checkout
# Get yours at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret — required for /api/webhooks/stripe
# Generate at https://dashboard.stripe.com/webhooks (or via `stripe listen` for local dev)
# Events to enable: checkout.session.completed, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# The URL of your deployed site — used for Stripe redirect URLs
NEXT_PUBLIC_BASE_URL=https://eve.center

# Porkbun API credentials — required for domain registration
# Get yours at https://porkbun.com/account/api
PORKBUN_API_KEY=pk1_...
PORKBUN_SECRET_KEY=sk1_...

# Contabo VPS public IP — Eve-built sites are served from this address
# All purchased domains have their DNS A record pointed here automatically
CONTABO_VPS_IP=1.2.3.4

# Contabo VPS SSH credentials — required for site build & deploy pipeline (BUS-35)
# CONTABO_SSH_USER defaults to 'root' if not set
CONTABO_SSH_USER=root
CONTABO_SSH_PORT=22

# SSH private key for VPS access.
# Two formats are accepted:
#   PEM format:    paste the key with literal \n line breaks (single line in .env)
#   Base64 format: base64-encode the full PEM key and paste the result
# Generate a dedicated deploy key: ssh-keygen -t ed25519 -C "eve-deploy" -f ~/.ssh/eve_deploy
# Then add the public key to the VPS: ssh-copy-id -i ~/.ssh/eve_deploy.pub root@<VPS_IP>
# Base64-encode: base64 -w 0 ~/.ssh/eve_deploy
CONTABO_SSH_PRIVATE_KEY=base64encodedkey...
