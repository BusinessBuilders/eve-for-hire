# OpenClaw gateway token — required for /chat (Eve's AI conversation interface)
# Eve handles AI on her own infrastructure; this token authenticates the VPS → OpenClaw call.
# Obtain from Eve or the board.
OPENCLAW_TOKEN=oc_...

# OpenClaw gateway URL — optional, defaults to https://nova.tailscale.io:18789
# Override if the VPS has a direct internal Tailscale route (faster, no TLS overhead)
# OPENCLAW_URL=http://100.105.14.117:18789

# Stripe secret key — required for tip jar payments and order checkout
# Get yours at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret — required for /api/webhooks/stripe
# Generate at https://dashboard.stripe.com/webhooks (or via `stripe listen` for local dev)
# Events to enable: checkout.session.completed, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# The URL of your deployed site — used for Stripe redirect URLs
NEXT_PUBLIC_BASE_URL=https://eve.center

# Porkbun API credentials — required for domain registration
# Get yours at https://porkbun.com/account/api
PORKBUN_API_KEY=pk1_...
PORKBUN_SECRET_KEY=sk1_...

# Contabo VPS public IP — Eve-built sites are served from this address
# All purchased domains have their DNS A record pointed here automatically
CONTABO_VPS_IP=1.2.3.4

# Contabo VPS SSH credentials — required for site build & deploy pipeline (BUS-35)
# CONTABO_SSH_USER defaults to 'root' if not set
CONTABO_SSH_USER=root
CONTABO_SSH_PORT=22

# SSH private key for VPS access.
# Two formats are accepted:
#   PEM format:    paste the key with literal \n line breaks (single line in .env)
#   Base64 format: base64-encode the full PEM key and paste the result
# Generate a dedicated deploy key: ssh-keygen -t ed25519 -C "eve-deploy" -f ~/.ssh/eve_deploy
# Then add the public key to the VPS: ssh-copy-id -i ~/.ssh/eve_deploy.pub root@<VPS_IP>
# Base64-encode: base64 -w 0 ~/.ssh/eve_deploy
CONTABO_SSH_PRIVATE_KEY=base64encodedkey...

# Order database path — optional, defaults to <cwd>/data/orders.db
# For production deployments, point this at a persistent volume outside the app root
# so that orders survive code redeploys (e.g. /var/data/orders.db).
# The parent directory is created automatically on first boot if it does not exist.
# ORDER_DB_PATH=/var/data/orders.db

# Paperclip Swarm Integration — required for delegating builds to agents (BUS-145)
# Public URL of the Paperclip API (e.g. via Tailscale Funnel)
# PAPERCLIP_API_URL=https://paperclip.your-funnel.ts.net
# Auth token for the triggering agent (obtain from Paperclip agent settings)
# PAPERCLIP_AGENT_TOKEN=pc_...
# The company ID where the build issues should be created
# PAPERCLIP_COMPANY_ID=73ea94d4-2b33-466b-8019-2e5fa03bc5c6
# (Optional) The project ID to associate build issues with
# PAPERCLIP_PROJECT_ID=68969dc8-d4a4-449e-8a2d-a4e828b04bc1
# Shared secret for authenticating build-result callbacks
# PAPERCLIP_CALLBACK_SECRET=secret_...

# Primary relational database used by Prisma/Auth.js
# Local default (SQLite)
DATABASE_URL=file:./data/eve-auth.db

# Auth.js secret for session/token encryption.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-secure-random-value

# GitHub OAuth app credentials for sign-in.
# Create OAuth app at https://github.com/settings/developers
# Callback URL (local): http://localhost:3000/api/auth/callback/github
# Callback URL (prod):  https://eve.center/api/auth/callback/github
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# Email (Magic Link) provider credentials
# Required for customer sign-in without GitHub.
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=user@example.com
EMAIL_SERVER_PASSWORD=your-smtp-password
EMAIL_FROM=Eve <noreply@eve.center>
