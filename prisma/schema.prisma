generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  sites         Site[]
  orders        Order[]
  affiliate     Affiliate?
  referral      Referral? @relation("ReferredUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id               String   @id @default(cuid())
  identifier       String   @unique
  seq              Int      @unique
  userId           String?
  customerEmail    String
  customerName     String?
  state            String   // OrderState
  idempotencyKey   String   @unique
  requirements     String?  // JSON stringified OrderRequirements
  payment          String?  // JSON stringified PaymentInfo
  domain           String?  // JSON stringified DomainInfo
  deploy           String?  // JSON stringified DeployInfo
  auditTrail       String   // JSON stringified AuditEntry[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User?    @relation(fields: [userId], references: [id])
  site             Site?
  contributions    MissionContribution[]
}

model Site {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?  @unique
  domain    String   @unique
  title     String?
  status    String   @default("draft")
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id])
  messages  ContactMessage[]

  @@index([userId])
  @@index([status])
}

model Affiliate {
  id             String     @id @default(cuid())
  userId         String     @unique
  code           String     @unique
  commissionRate Float      @default(0.25)
  totalEarned    Int        @default(0) // in cents
  totalWithdrawn Int        @default(0) // in cents
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals      Referral[]
}

model Referral {
  id               String    @id @default(cuid())
  affiliateId      String
  referredUserId   String    @unique
  status           String    @default("PENDING") // PENDING, PAID
  commissionAmount Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  affiliate        Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUser     User      @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id          String   @id @default(cuid())
  siteId      String
  domain      String
  senderName  String
  senderEmail String
  message     String
  createdAt   DateTime @default(now())

  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model MissionProgress {
  id           String   @id @default("current")
  totalRaised  Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model MissionContribution {
  id        String   @id @default(cuid())
  orderId   String?
  amount    Int      // in cents
  type      String   // SALE_PORTION, TIP
  createdAt DateTime @default(now())

  order     Order?   @relation(fields: [orderId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  sessionId String?
  orderId   String?
  domain    String?
  email     String?
  props     String?  // JSON stringified extra props
  ts        DateTime @default(now())

  @@index([event])
  @@index([ts])
}

model DraftPreview {
  id           String   @id @default(cuid())
  token        String   @unique
  sessionId    String
  businessName String
  tagline      String?
  category     String?
  primaryColor String   @default("#4F46E5")
  heroHtml     String
  viewCount    Int      @default(0)
  ctaClicked   Boolean  @default(false)
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([token])
  @@index([sessionId])
}
